{
  "name": "@impresairio/cli",
  "version": "0.1.0",
  "description": "A local CLI for durable, human-gated AI-assisted engineering workflows.",
  "license": "MIT",
  "repository": "https://github.com/remyjallan/impresairio.git",
  "homepage": "https://github.com/remyjallan/impresairio#readme",
  "bugs": "https://github.com/remyjallan/impresairio/issues",
  "private": false,
  "keywords": [
    "ai",
    "agents",
    "cli",
    "engineering",
    "workflow"
  ],
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "impresairio": "dist/main.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-workflow-assets.mjs",
    "prepack": "npm run build",
    "test": "npm run build && vitest",
    "test:run": "npm run build && vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "verify": "npm run test:run && npm run typecheck && npm run lint && npm run build",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "nest-commander": "^3.20.1",
    "reflect-metadata": "^0.2.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
